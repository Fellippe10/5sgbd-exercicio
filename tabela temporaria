CREATE TEMP TABLE tmp_pedidos_raw (
    codigoPedido VARCHAR(50),
    dataPedido VARCHAR(10),
    SKU VARCHAR(100),
    UPC VARCHAR(50),
    nomeProduto VARCHAR(255),
    qtd VARCHAR(10),
    valor_unit VARCHAR(20),
    frete_item VARCHAR(20),
    email VARCHAR(255),
    codigoComprador VARCHAR(50),
    nomeComprador VARCHAR(255),
    endereco VARCHAR(500),
    CEP VARCHAR(20),
    UF VARCHAR(2),
    pais VARCHAR(50)
);

COPY tmp_pedidos_raw 
FROM 'pedidos.txt' 
WITH (FORMAT CSV, DELIMITER ';', HEADER TRUE);

INSERT INTO clientes (id_cliente, nome, email, cep, endereco, uf, pais)
SELECT DISTINCT 
    codigoComprador::INT, nomeComprador, email, CEP, endereco, UF, pais
FROM tmp_pedidos_raw
ON CONFLICT (id_cliente) DO UPDATE SET 
    endereco = EXCLUDED.endereco, 
    cep = EXCLUDED.cep;

INSERT INTO produtos (sku, upc, nome)
SELECT DISTINCT SKU, UPC, nomeProduto
FROM tmp_pedidos_raw
ON CONFLICT (sku) DO NOTHING;

INSERT INTO pedidos (codigo_pedido, data_pedido, id_cliente, valor_total)
SELECT 
    codigoPedido,
    dataPedido::DATE,
    codigoComprador::INT,
    SUM(REPLACE(valor_unit, ',', '.')::DECIMAL * qtd::INT) + 
    MAX(REPLACE(frete_item, ',', '.')::DECIMAL)
FROM tmp_pedidos_raw
GROUP BY codigoPedido, dataPedido, codigoComprador
ON CONFLICT (codigo_pedido) DO NOTHING;

INSERT INTO compra (codigo_pedido, sku, quantidade, valor_unitario)
SELECT 
    codigoPedido, 
    SKU, 
    qtd::INT, 
    REPLACE(valor_unit, ',', '.')::DECIMAL
FROM tmp_pedidos_raw;

INSERT INTO expedicao (codigo_pedido, status)
SELECT DISTINCT codigoPedido, 'Pendente'
FROM tmp_pedidos_raw
ON CONFLICT DO NOTHING;
